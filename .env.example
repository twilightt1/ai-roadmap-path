# Supabase browser/client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL used by metadata, sitemap/robots, and auth redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# P0 capability flags. Values must be true/false or 1/0.
# Worker-backed execution is enabled by default. Set false to disable all code execution;
# the UI shows a maintenance message and never falls back to same-window execution.
NEXT_PUBLIC_P0_WORKER_EXECUTION=true

# LWW progress sync is disabled by default. Set true only after rollout validation.
# When false, progress remains local and no remote progress mutation RPCs are made.
NEXT_PUBLIC_P0_LWW_PROGRESS=false

# Practice ladder is disabled by default. Set true to expose ladder content.
NEXT_PUBLIC_P0_PRACTICE_LADDER=false

# P1 deterministic learning loop (diagnostic, weekly goal, mastery estimate).
# Enable only after the P1 learning_profiles migration and RLS/RPC checks pass.
NEXT_PUBLIC_P1_LEARNING_LOOP=false

# P2 private project evidence drafts and deterministic manual-review rubric.
# Enable only after the P2 project_evidence migration and RLS/RPC checks pass.
NEXT_PUBLIC_P2_PROJECT_EVIDENCE=false

# Server-only/admin workflows only. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=
