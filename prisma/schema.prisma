// Prisma schema legacy/future/reference only — KHÔNG phải hướng triển khai Phase 1 production.
// Phase 1 production auth/user-data path: Supabase Auth + Supabase PostgreSQL.
// Không cài Prisma/NextAuth hoặc chạy Prisma migrate cho Phase 1 từ file này.
//
// Generator cho PostgreSQL. Cấu trúc tham khảo bám sát lib/types.ts để dễ map dữ liệu nếu cần về sau.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress      UserPhaseProgress[]
  projectsDone  UserProject[]
  skills        UserSkill[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

// Theo dõi tiến độ từng phase (0 = chưa xem, 1 = đang học, 2 = hoàn thành)
model UserPhaseProgress {
  id       String @id @default(cuid())
  userId   String
  phaseId  Int
  status   Int   @default(0) // 0=todo, 1=in-progress, 2=done
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phaseId])
  @@index([userId])
  @@map("user_phase_progress")
}

// Project đã hoàn thành
model UserProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  phaseId   Int
  link      String? // repo / demo URL
  completedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@map("user_projects")
}

// Kỹ năng người dùng tự đánh dấu đã học
model UserSkill {
  id       String @id @default(cuid())
  userId   String
  skill    String
  tier     Int // 1 | 2 | 3
  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
  @@map("user_skills")
}

// --- NextAuth.js tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
